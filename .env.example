# Copy to .env and fill in values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker (docker-compose up db):
DATABASE_URL=postgresql://eventtrace:eventtrace@localhost:5432/eventtrace

# Supabase (replace with your project values):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Leave empty to use SQLite (dev fallback):
# DATABASE_URL=

# ── Notifications ─────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=Eventtrace_bot
# Your personal Telegram chat ID — get it from @userinfobot
# Used for admin alerts (causelist scrape failures)
ADMIN_CHAT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
CHD_PUBLIC_URL=

# ── WhatsApp (MSG91) ──────────────────────────────────────────────────────────
# MSG91 auth key (same key used for OTP — reused here for WhatsApp)
MSG91_AUTH_KEY=
# Your MSG91 integrated WhatsApp Business number (digits only, no +)
# e.g. 919876543210 — find it in MSG91 dashboard → WhatsApp → Integrated Number
MSG91_WHATSAPP_NUMBER=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get API key from resend.com — free tier: 100 emails/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender address (domain must be verified in Resend dashboard)
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS. Use * for dev, restrict in prod.
CORS_ORIGINS=*
# API key required on POST /alert (leave empty to disable auth)
CHD_ALERT_API_KEY=

# ── Optional overrides (defaults shown) ──────────────────────────────────────
# CHD_DB_PATH=./data/eventtrace.sqlite3
# CHD_POLL_SECONDS=15
# CHD_API_HOST=127.0.0.1   ← set to 0.0.0.0 in production (Docker/Railway)
# CHD_API_PORT=8009
